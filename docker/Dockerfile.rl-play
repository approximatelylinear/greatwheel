FROM python:3.12-slim-bookworm

RUN pip install uv

WORKDIR /app

# Install rl-play from local source (mounted or copied)
COPY . /app/
RUN uv pip install --system -e .

# Override hardcoded Ollama URL for Docker networking
ENV OLLAMA_BASE_URL=http://ollama:11434

EXPOSE 8000

CMD ["rl-play", "serve", "--host", "0.0.0.0", "--port", "8000"]
